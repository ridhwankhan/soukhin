# Vite frontend (use these names — NOT NEXT_PUBLIC_*)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...   # or legacy eyJ... anon JWT from Settings → API

# Optional alias (same value as ANON_KEY if using new publishable keys)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Production site URL (used for bKash origin check + load tests)
VITE_SITE_URL=https://your-domain.com

# Enable bKash button on checkout when edge function is deployed
VITE_BKASH_ENABLED=false

# --- Supabase Edge Function secrets (set in Supabase dashboard, NOT in Vite) ---
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# BKASH_USERNAME=
# BKASH_PASSWORD=
# BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
# ALLOWED_SITE_ORIGINS=https://your-domain.com,https://www.your-domain.com
# SUPABASE_ANON_KEY= (same as above — needed inside edge function for JWT verify)

# --- Supabase Auth redirect URLs (Dashboard → Authentication → URL Configuration) ---
# Site URL: https://your-domain.com
# Redirect URLs: https://your-domain.com/auth?verified=1

# --- Run migrations in order (004 through 008) before first deploy ---
# supabase db push  OR paste SQL files in Supabase SQL Editor

# --- Load test before launch ---
# npm run load-test
